task.spawn(function()
    local totalTime = 3
    local startTick = tick()
    local msgIndex = 1
    
    while tick() - startTick < totalTime do
        local elapsed = tick() - startTick
        local progress = elapsed / totalTime
        
        BarFill.Size = UDim2.new(progress, 0, 1, 0)
        PercentText.Text = math.floor(progress * 100) .. "%"
        
        local currentMsgIndex = math.floor(elapsed / 0.15) + 1
        if statusMessages[currentMsgIndex] and currentMsgIndex ~= msgIndex then
            msgIndex = currentMsgIndex
            StatusLabel.Text = statusMessages[msgIndex]
        end
        
        task.wait()
    end
    
    BarFill.Size = UDim2.new(1, 0, 1, 0)
    PercentText.Text = "100%"
    StatusLabel.Text = "đã xong"
    
    task.wait(0.3)
    
    local fadeInfo = TweenInfo.new(0.4, Enum.EasingStyle.Linear)
    local objectsToFade = {LoadingFrame, LoadingTitle, BarBG, BarFill, PercentText, StatusLabel}
    for _, obj in pairs(objectsToFade) do
        if obj:IsA("Frame") then
            TweenService:Create(obj, fadeInfo, {BackgroundTransparency = 1}):Play()
        elseif obj:IsA("TextLabel") then
            TweenService:Create(obj, fadeInfo, {TextTransparency = 1}):Play()
        end
    end
    
    task.wait(0.4)
    LoadingFrame:Destroy()
    if _G.MainFrame then _G.MainFrame.Visible = true end
end)

