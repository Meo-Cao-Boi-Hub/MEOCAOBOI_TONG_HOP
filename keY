-- NÚT TELE (V/B/L) MỚI
CreateBtn("tele (V/B/L)", function()
    -- [BẮT ĐẦU CODE TELE MEO CAO BỒI]
    local Player = game.Players.LocalPlayer
    local savedPosition = nil
    local isNoclipping = false
    local Character = Player.Character or Player.CharacterAdded:Wait()
    local RootPart = Character:WaitForChild("HumanoidRootPart")
    local DURATION = 0.35 

    Player.CharacterAdded:Connect(function(newCharacter)
        Character = newCharacter; RootPart = Character:WaitForChild("HumanoidRootPart"); isNoclipping = false
    end)

    local function notify(msg)
        game:GetService("StarterGui"):SetCore("SendNotification", {Title = "MEOCAOBOI", Text = msg, Duration = 3})
    end

    RunService.Stepped:Connect(function()
        if isNoclipping and Character then
            for _, part in pairs(Character:GetDescendants()) do if part:IsA("BasePart") then part.CanCollide = false end end
        end
    end)

    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed or not RootPart then return end
        if input.KeyCode == Enum.KeyCode.V then
            savedPosition = RootPart.CFrame
            local pos = savedPosition.Position
            notify("tọa độ đã lưu: [" .. math.floor(pos.X) .. ", " .. math.floor(pos.Y) .. ", " .. math.floor(pos.Z) .. "]")
        elseif input.KeyCode == Enum.KeyCode.B then
            if savedPosition then
                isNoclipping = true
                local tween = TweenService:Create(RootPart, TweenInfo.new(DURATION, Enum.EasingStyle.Linear), {CFrame = savedPosition})
                tween:Play()
                tween.Completed:Connect(function()
                    task.wait(0.05); isNoclipping = false
                    if Character then for _, part in pairs(Character:GetDescendants()) do if part:IsA("BasePart") then part.CanCollide = true end end end
                    notify("Đã kéo về!")
                end)
            end
        elseif input.KeyCode == Enum.KeyCode.L then
            if savedPosition then
                RootPart.Velocity = Vector3.new(0,0,0); RootPart.CFrame = savedPosition
                notify("Đã dịch chuyển!")
            end
        end
    end)
    notify("V:lưu, B:kéo, L:tele đã kích hoạt!")
end)

