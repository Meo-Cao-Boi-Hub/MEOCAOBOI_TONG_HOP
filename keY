-- Hàm màu cầu vồng cho viền
local function MakeRainbow(obj, property)
    task.spawn(function()
        while obj and obj.Parent do
            local hue = tick() % 5 / 5
            obj[property] = Color3.fromHSV(hue, 0.8, 1)
            task.wait()
        end
    end)
end

