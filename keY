local Tabs = {}
local function CreateTab(name)
    local TabBtn = Instance.new("TextButton", TabHolder)
    TabBtn.Size = UDim2.new(0, 150, 1, 0) -- Độ rộng cố định cho nút tab
    TabBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    TabBtn.Text = name
    TabBtn.Font = Enum.Font.GothamBold
    TabBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
    TabBtn.TextSize = 14
    Instance.new("UICorner", TabBtn)
    
    local Scroll = Instance.new("ScrollingFrame", ContainerHolder)
    Scroll.Size = UDim2.new(1, -20, 1, -10)
    Scroll.Position = UDim2.new(0, 10, 0, 5)
    Scroll.BackgroundTransparency = 1
    Scroll.Visible = false
    Scroll.ScrollBarThickness = 3
    
    local List = Instance.new("UIListLayout", Scroll)
    List.Padding = UDim.new(0, 8)
    List.HorizontalAlignment = Enum.HorizontalAlignment.Center
    
    TabBtn.MouseButton1Click:Connect(function()
        for _, t in pairs(Tabs) do 
            t.S.Visible = false
            t.B.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
            t.B.TextColor3 = Color3.fromRGB(200, 200, 200)
        end
        Scroll.Visible = true
        TabBtn.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
        TabBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    end)
    
    Tabs[name] = {B = TabBtn, S = Scroll}
    return Scroll
end

local function CreateBtn(parent, name, script_func)
    local btn = Instance.new("TextButton", parent)
    btn.Size = UDim2.new(0.9, 0, 0, 40)
    btn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    btn.Text = name
    btn.Font = Enum.Font.Gotham
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    Instance.new("UICorner", btn)
    
    btn.MouseButton1Click:Connect(function() script_func() end)
    
    -- Tự động cập nhật CanvasSize
    parent.CanvasSize = UDim2.new(0, 0, 0, parent.UIListLayout.AbsoluteContentSize.Y + 20)
end

